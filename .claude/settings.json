{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/normalize-timestamp.sh",
            "timeout": 10,
            "statusMessage": "Normalizing frontmatter..."
          }
        ]
      }
    ]
  }
}
