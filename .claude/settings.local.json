{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(cd*)",
      "Bash(STUDY_PUSH_CONTENT_ACK=1 git *)",
      "Bash(grep *)",
      "Read(//tmp/**)",
      "Bash(python3 *)",
      "Skill(update-config)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sequential-thinking"
  ],
  "statusLine": {
    "type": "command",
    "command": "python C:/Users/user/.claude/statusline.py",
    "padding": 2,
    "refreshInterval": 10
  }
}
