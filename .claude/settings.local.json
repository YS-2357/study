{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(cd*)",
      "Bash(STUDY_PUSH_CONTENT_ACK=1 git *)",
      "Bash(grep *)",
      "Read(//tmp/**)",
      "Bash(python3 *)",
      "Skill(update-config)",
      "Bash(where python *)",
      "Bash(where python3 *)",
      "Bash(python -m json.tool)",
      "Bash(python \"C:/Users/USER/.claude/statusline.py\")",
      "Bash(where python.exe)",
      "Bash(py --version)",
      "Bash(python3.exe --version)",
      "Bash(/c/Users/USER/AppData/Local/Microsoft/WindowsApps/python.exe --version)",
      "Bash(py *)",
      "Bash(command -v python)",
      "Bash(command -v python3)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sequential-thinking"
  ],
  "statusLine": {
    "type": "command",
    "command": "python C:/Users/user/.claude/statusline.py",
    "padding": 2,
    "refreshInterval": 10
  }
}
